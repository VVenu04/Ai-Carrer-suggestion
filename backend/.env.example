# Local dev: copy this file to `.env` and add your key (never commit `.env`).
# Railway: set secrets only in the service Variables tab — do not put keys in this file.
#
# In your real `.env` you need:
#   OPENROUTER_API_KEY=sk-or-v1-...   (from https://openrouter.ai/keys)
#
# This example file intentionally omits any OPENROUTER_* assignment so automated
# builders do not require that value at image build time.

# Optional defaults (safe to commit):
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_TEMPERATURE=0.7
SQLITE_PATH=./career_app.sqlite
